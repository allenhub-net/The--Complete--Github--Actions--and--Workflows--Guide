{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "dependencyDashboardAutoclose": true,
  "packageRules": [
    {
      "matchManagers": ["github-actions"],
      "includeBranches": ["*"],
      "versioning": "github-commits",
      "pinDigests": true
    }
  ]
}
