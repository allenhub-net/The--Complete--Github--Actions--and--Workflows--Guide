{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "dependencyDashboardAutoclose": true,
  "packageRules": [
    {
      "matchManagers": [
        "github-actions"
      ],
      "pinDigests": true,
      "versioning": "github-commits",
      "rangeStrategy": "pin",
      "dependencyDashboardApproval": false
    }
  ]
}