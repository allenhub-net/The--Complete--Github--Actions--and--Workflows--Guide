{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "dependencyDashboardAutoclose": true,
  "dependencyDashboard": true,
  "dependencyDashboardApproval": false,
  "packageRules": [
    {
      "matchManagers": [
        "github-actions"
      ],
      "pinDigests": true,
      "versioning": "github-commits",
      "rangeStrategy": "pin"
    }
  ],
  "branches": [
    "main",
    {
      "pattern": "^section--[0-9]*"
    }
  ]
}