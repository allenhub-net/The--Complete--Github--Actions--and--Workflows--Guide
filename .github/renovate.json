{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":prImmediately"
  ],
  "dependencyDashboardAutoclose": true,
  "prCreation": "immediate",
  "packageRules": [
    {
      "matchManagers": ["github-actions"],
      "pinDigests": true,
      "versioning": "github-commits",
      "rangeStrategy": "pin"
    }
  ]
}